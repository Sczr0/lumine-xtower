# Lumine — VPS 端 Caddy 配置
# 角色: 接收 CHAME CDN / Cloudflare 回源，分发到后端和静态文件
#
# 放置: /etc/caddy/Caddyfile
# 重载: sudo systemctl reload caddy
#
# 流量路径:
#   lumine.xtower.site → CHAME CDN → VPS Caddy → /v1/* → :3000
#                                                  /*    → 静态文件
#   admin.lumine.xtower.site → CF Zero Trust → VPS Caddy → /admin/* → :3000
#                                                          /*       → tagging 静态

# ============================================================
# 主站: lumine.xtower.site（被 CHAME CDN 回源）
# ============================================================
# CHAME CDN 回源通常走 HTTP，所以只监听 :80 即可
lumine.xtower.site:80 {
    # API → Rust 后端
    handle /v1/* {
        reverse_proxy localhost:3000 {
            header_up Host {host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # 打标台（保留，方便调试）
    handle /tagging/* {
        root * /opt/lumine/static/tagging
        file_server
    }

    # 静态资源（带 hash，长缓存）
    handle /_assets/* {
        root * /opt/lumine/static
        file_server
    }

    # 首页等页面
    handle {
        root * /opt/lumine/static
        file_server
    }

    log {
        output file /var/log/caddy/lumine.log {
            roll_size 10MiB
            roll_keep 3
        }
    }
}

# ============================================================
# 后台: admin.lumine.xtower.site（被 Cloudflare 回源）
# ============================================================
# 关键: CF SSL/TLS 设为 Full (strict)，需要 Caddy 提供有效证书
# 方案: 在 CF 面板 → SSL/TLS → Origin Server → 创建 Origin Certificate
#       下载 cert.pem 和 key.pem，放到 /etc/caddy/certs/
#
admin.lumine.xtower.site:443 {
    # CF Origin Certificate
    tls /etc/caddy/certs/admin.lumine.xtower.site.pem \
        /etc/caddy/certs/admin.lumine.xtower.site.key

    # API（打标台调用）
    handle /admin/* {
        reverse_proxy localhost:3000 {
            header_up Host {host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # 打标台 SPA
    handle {
        root * /opt/lumine/static/tagging
        try_files {path} /index.html
        file_server
    }

    log {
        output file /var/log/caddy/admin.log {
            roll_size 10MiB
            roll_keep 3
        }
    }
}
